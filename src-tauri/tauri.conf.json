{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "CostDog",
  "version": "0.1.2",
  "identifier": "com.costdog.app",
  "build": {
    "frontendDist": "./embedded",
    "devUrl": "http://localhost:3456",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "CostDog",
        "width": 410,
        "height": 36,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.ico"
    ]
  }
}
